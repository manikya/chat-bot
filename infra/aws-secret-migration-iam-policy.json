{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListCommerceChatSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:ListSecrets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadAndDeleteCommerceChatSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue",
        "secretsmanager:DeleteSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:960884446408:secret:commercechat/*"
    },
    {
      "Sid": "WriteTenantCredentialRecords",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:960884446408:table/commercechat-dev-storage-main"
    }
  ]
}
