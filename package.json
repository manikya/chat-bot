{
  "name": "commercechat",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "npm run dev --workspace=@commercechat/api",
    "dev:ui": "npm run dev --workspace=@commercechat/admin",
    "dev:mobile": "npm run dev --workspace=@commercechat/mobile",
    "dev:ngrok:ui": "ngrok http 3000 --log=stdout",
    "dev:ngrok:api": "ngrok http 3001 --log=stdout",
    "build": "npm run build:lambdas && npm run build --workspace=@commercechat/admin",
    "build:api": "npm run build --workspace=@commercechat/api",
    "build:ui": "npm run build --workspace=@commercechat/admin",
    "start": "concurrently -n api,ui -c blue,green \"npm run start --workspace=@commercechat/api\" \"npm run start --workspace=@commercechat/admin\"",
    "lint": "npm run lint --workspace=@commercechat/admin",
    "build:lambdas": "npm run build:lambdas --workspace=@commercechat/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "cost:aws": "node scripts/aws-cost-report.mjs",
    "deploy:aws": "node scripts/deploy-aws-serverless.mjs",
    "ensure:deploy-iam": "node scripts/ensure-deploy-iam.mjs",
    "deploy:widget": "node scripts/deploy-widget-static.mjs",
    "deploy:aws:full": "node scripts/deploy-aws-serverless.mjs --env=dev --with-ingest-pipeline --with-ingest-step-functions --with-widget-cdn --ensure-iam",
    "deploy:admin": "node scripts/deploy-admin-static.mjs",
    "build:woocommerce-plugin": "node scripts/build-woocommerce-plugin.mjs",
    "eval:chat": "node apps/api/scripts/eval-chat/run.mjs",
    "eval:retrieval": "EVAL_CASES_PATH=apps/api/scripts/eval-chat/retrieval-cases.json node apps/api/scripts/eval-chat/run.mjs",
    "eval:chat:experiments": "node apps/api/scripts/eval-chat/run-experiments.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
