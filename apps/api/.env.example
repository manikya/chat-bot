PORT=3001
TABLE_NAME=CommerceChat-Main
DYNAMODB_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
JWT_SECRET=dev-only-change-in-production
# Local dev only — auto-verify email on signup and allow login without verify link
# SKIP_EMAIL_VERIFICATION=true
JWT_ISSUER=commercechat.com
APP_URL=http://localhost:3000

# SMTP (Zoho, etc.) — when set, auth emails send for real instead of console logs
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your-app-password
# SMTP_FROM=CommerceChat <you@yourdomain.com>
# When exposing admin via ngrok for Meta OAuth: APP_URL=https://<ngrok-id>.ngrok-free.dev
API_PUBLIC_URL=http://localhost:3001
DATA_DIR=.data

# S3 Vectors (required for RAG — use dev bucket name after deploy:aws)
# S3_VECTORS_BUCKET=commercechat-dev-vectors
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# S3 assets (LocalStack: http://localhost:4566) — presigned logo upload
# S3_ENDPOINT=http://localhost:4566
# S3_BUCKET=commercechat-assets
# S3_PUBLIC_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
INGEST_MAX_PAGES=50
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Meta / WhatsApp (Capricon WA Connector)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token
META_GRAPH_VERSION=v21.0
META_SYSTEM_USER_ID=your-system-user-id

# Dev manual WhatsApp connect (until OAuth ships) — from WhatsApp → API Setup
META_DEV_WABA_ID=your-waba-id
META_DEV_PHONE_NUMBER_ID=your-phone-number-id
META_DEV_DISPLAY_PHONE=+10000000000
META_DEV_ACCESS_TOKEN=your-system-user-access-token

# Dev manual Messenger connect — Page ID + Page access token from Meta Graph API Explorer
# META_DEV_PAGE_ID=your-facebook-page-id
# META_DEV_PAGE_ACCESS_TOKEN=your-page-access-token
# META_DEV_PAGE_NAME=My Store Page
# Local OAuth needs HTTPS — expose admin on ngrok :3000 and whitelist this exact URI in Meta
# META_OAUTH_REDIRECT_URI=https://<ngrok-id>.ngrok-free.dev/channels/meta/callback
META_OAUTH_REDIRECT_URI=http://localhost:3000/channels/meta/callback
# Webhooks: ngrok admin :3000 (Next.js rewrites /webhooks/* → API :3001)
# Whitelist in Meta → Webhooks: https://<ngrok-id>.ngrok-free.dev/webhooks/meta
# Subscribe Page object fields: messages, messaging_postbacks

# Meta / WordPress credential storage backend: file | dynamodb | secrets-manager
# Local dev: file (.data/meta) — AWS deploy: dynamodb (see .env.aws.example)
META_SECRETS_BACKEND=file

# AWS deployment — copy .env.aws.example → .env.aws (gitignored)
# Deploy loads .env then .env.aws: npm run deploy:aws
# Legacy Secrets Manager path (still supported when backend=secrets-manager):
# SECRETS_MANAGER_ENDPOINT=http://localhost:4566
# META_SECRETS_USE_SECRETS_MANAGER=true
# META_SECRETS_PREFIX=commercechat
# META_TOKEN_REFRESH_CRON_SECRET=dev-cron-secret
# META_TOKEN_REFRESH_INTERVAL_MS=3600000
# POST /internal/cron/meta-token-refresh (header X-Cron-Secret when secret set)

# Billing — Sri Lankan / external payment gateway (not Stripe)
# PAYMENT_GATEWAY_CHECKOUT_URL=https://pay.example.lk/checkout?ref={checkoutId}&amount={amountLkr}&plan={plan}
# PAYMENT_WEBHOOK_SECRET=your-shared-webhook-secret
# BILLING_SKIP_PAYMENT=true
