# ── AWS deployment template (copy to .env.aws and fill secrets) ───────────────
# Deploy: npm run deploy:aws  (loads .env then .env.aws)
# E2E:    API_URL=https://... node apps/api/scripts/test-page-voice.mjs

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
AWS_CREDENTIALS_CSV=/path/to/accessKeys.csv

# From infra/deployments/commercechat-{env}-*.json after first deploy
APP_URL=https://your-admin.cloudfront.net
API_PUBLIC_URL=https://your-api.execute-api.us-east-1.amazonaws.com
API_URL=https://your-api.execute-api.us-east-1.amazonaws.com
META_OAUTH_REDIRECT_URI=https://your-admin.cloudfront.net/channels/meta/callback
META_WEBHOOK_PUBLIC_URL=https://your-api.execute-api.us-east-1.amazonaws.com/webhooks/meta

# DynamoDB — real AWS (omit DYNAMODB_ENDPOINT)
TABLE_NAME=commercechat-dev-storage-main
AWS_TABLE_NAME=commercechat-dev-storage-main

# S3 assets + vectors (from CloudFormation outputs)
S3_BUCKET=commercechat-dev-assets-ACCOUNT-us-east-1
S3_ASSETS_BUCKET=commercechat-dev-assets-ACCOUNT-us-east-1
S3_VECTORS_BUCKET=commercechat-dev-vectors

DATA_DIR=/tmp/commercechat
META_SECRETS_BACKEND=dynamodb
META_SECRETS_PREFIX=commercechat

SKIP_EMAIL_VERIFICATION=true
BILLING_SKIP_PAYMENT=true

JWT_SECRET=generate-a-strong-secret
JWT_ISSUER=commercechat.com
OPENAI_API_KEY=sk-your-key
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
PLANNER_MODEL=gpt-4o-mini
ESCALATION_MODEL=
AI_WALLET_USD_TO_LKR=310
AI_WALLET_MARKUP_PCT=30
AI_WALLET_LOW_BALANCE_MINOR=50000
INGEST_MAX_PAGES=50

META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token
META_GRAPH_VERSION=v21.0

SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=CommerceChat <you@yourdomain.com>
